// ============================================================
// Khối xử lý xung đột (Hazard Unit - Fig 3.15)
// Inputs : 12
// Outputs: 6 (StallF, StallD, FlushD, FlushE, ForwardAE, ForwardBE)
// ============================================================
`timescale 1ns/1ps

module hazard_unit (
    // Load-use hazard detection
    input  wire        MemtoRegE,   // lệnh tải đang ở EX
    input  wire [4:0]  RS1D,        // rs1 của lệnh ở ID
    input  wire [4:0]  RS2D,        // rs2 của lệnh ở ID
    input  wire [4:0]  RDE,         // rd  của lệnh ở EX
    // Forwarding
    input  wire [4:0]  RS1E,        // rs1 của lệnh ở EX
    input  wire [4:0]  RS2E,        // rs2 của lệnh ở EX
    input  wire [4:0]  RDM,         // rd  của lệnh ở MA
    input  wire [4:0]  RDW,         // rd  của lệnh ở WB
    input  wire        RegWriteM,
    input  wire        RegWriteW,
    // Control hazard (branch/jump taken)
    input  wire [1:0]  PCSrcE,
    input  wire        RESET,
    // ---- Outputs ----
    output reg         StallF,
    output reg         StallD,
    output reg         FlushD,
    output reg         FlushE,
    output reg  [1:0]  ForwardAE,
    output reg  [1:0]  ForwardBE
);

    // ---- Forwarding logic (Fig 3.15 lower half) ----
    always @(*) begin
        // ForwardAE
        if (RegWriteM && (RDM != 5'd0) && (RDM == RS1E))
            ForwardAE = 2'b10;           // forward from EX/MA
        else if (RegWriteW && (RDW != 5'd0) && (RDW == RS1E))
            ForwardAE = 2'b01;           // forward from MA/WB
        else
            ForwardAE = 2'b00;           // use register file value

        // ForwardBE
        if (RegWriteM && (RDM != 5'd0) && (RDM == RS2E))
            ForwardBE = 2'b10;
        else if (RegWriteW && (RDW != 5'd0) && (RDW == RS2E))
            ForwardBE = 2'b01;
        else
            ForwardBE = 2'b00;
    end

    // ---- Load-use hazard: stall 1 cycle (Fig 3.15 upper half) ----
    wire lw_stall = MemtoRegE &&
                    ((RDE == RS1D) || (RDE == RS2D));

    always @(*) begin
        if (RESET) begin
            StallF = 1'b0;
            StallD = 1'b0;
            FlushE = 1'b0;
        end else if (lw_stall) begin
            StallF = 1'b1;  // freeze PC
            StallD = 1'b1;  // freeze IF/ID
            FlushE = 1'b1;  // insert bubble into ID/EX
        end else begin
            StallF = 1'b0;
            StallD = 1'b0;
            FlushE = 1'b0;
        end
    end

    // ---- Control hazard: flush 2 instructions (branch/jump taken) ----
    always @(*) begin
        if (RESET)
            FlushD = 1'b0;
        else if (PCSrcE == 2'b01 || PCSrcE == 2'b10)
            FlushD = 1'b1;  // flush IF/ID (+ FlushE handles ID/EX)
        else
            FlushD = 1'b0;
    end

endmodule
