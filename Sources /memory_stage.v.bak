// ============================================================
// Khối truy cập bộ nhớ (Memory Access - MA)
// ============================================================
`timescale 1ns/1ps

module memory_stage (
    input  wire        CLK,
    input  wire        RESET,
    // From EX/MA register
    input  wire        RegWriteM,
    input  wire [1:0]  ResultSrcM,
    input  wire        MemWriteM,
    input  wire [31:0] AluResultM,
    input  wire [31:0] WriteDataM,
    input  wire [4:0]  RDM,
    input  wire [31:0] PCPlus4M,
    // ---- Outputs (through MA/WB register) ----
    output reg         RegWriteW,
    output reg  [1:0]  ResultSrcW,
    output reg  [31:0] AluResultW,
    output reg  [31:0] ReaddataW,
    output reg  [4:0]  RDW,
    output reg  [31:0] PCPlus4W,
    // Pass-through for hazard (combinational)
    output wire [4:0]  RDM_out
);

    assign RDM_out = RDM;

    // ---- Data Memory (RAM) ----
    reg [31:0] dmem [0:255];

    integer i;
    initial begin
        for (i = 0; i < 256; i = i + 1)
            dmem[i] = 32'd0;
    end

    wire [31:0] ReadData;

    // Write on rising edge
    always @(posedge CLK) begin
        if (MemWriteM)
            dmem[AluResultM[9:2]] <= WriteDataM;
    end

    // Read combinationally
    assign ReadData = dmem[AluResultM[9:2]];

    // ---- MA/WB Pipeline Register ----
    always @(posedge CLK or posedge RESET) begin
        if (RESET) begin
            RegWriteW  <= 1'b0;
            ResultSrcW <= 2'b00;
            AluResultW <= 32'd0;
            ReaddataW  <= 32'd0;
            RDW        <= 5'd0;
            PCPlus4W   <= 32'd0;
        end else begin
            RegWriteW  <= RegWriteM;
            ResultSrcW <= ResultSrcM;
            AluResultW <= AluResultM;
            ReaddataW  <= ReadData;
            RDW        <= RDM;
            PCPlus4W   <= PCPlus4M;
        end
    end

endmodule
